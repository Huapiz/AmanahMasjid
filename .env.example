# Koneksi Postgres dari Neon (ambil dari dashboard Neon > Connection string).
# Gunakan connection string yang mengandung "-pooler" untuk aplikasi.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Kunci rahasia untuk enkripsi cookie sesi (iron-session).
# WAJIB minimal 32 karakter. Buat acak, misalnya:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="ganti-dengan-string-acak-minimal-32-karakter"
